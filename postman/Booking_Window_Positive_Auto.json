	"item": [
		{
			"name": "Успешное создание заявки",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 201 Created\", () => {\r",
							"    pm.response.to.have.status(201);\r",
							"});\r",
							"pm.test(\"Response time is less than 500ms\", () => {\r",
							"    pm.expect(pm.response.responseTime).to.be.below(500);\r",
							"});\r",
							"pm.test(\"Response has the same data as request\", () => {\r",
							"    const responseData = pm.response.json();\r",
							"    const requestData = JSON.parse(pm.request.body.raw);\r",
							"    pm.expect(responseData).to.include.keys(Object.keys(requestData));\r",
							"    pm.expect(responseData.name).to.eql(requestData.name);\r",
							"    pm.expect(responseData.email).to.eql(requestData.email);\r",
							"    pm.expect(responseData.phone).to.eql(requestData.phone);\r",
							"});\r",
							"pm.test(\"Response contains an 'id' field\", () => {\r",
							"    const responseData = pm.response.json();\r",
							"    pm.expect(responseData).to.have.property('id');\r",
							"});"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\r\n    \"name\": \"Иван Петров\",\r\n    \"email\": \"ivan.petrov@example.com\",\r\n    \"phone\": \"+79123456789\"\r\n}"
				},
				"url": {
					"raw": "https://jsonplaceholder.typicode.com/posts",
					"protocol": "https",
					"host": [
						"jsonplaceholder",
						"typicode",
						"com"
					],
					"path": [
						"posts"
					]
				}
			},
			"response": []
		},
